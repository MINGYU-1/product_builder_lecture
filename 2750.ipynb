   "source": [
    "arr = list(map(int,input()))\n",
    "for i in range(len(arr)):\n",
    "    for j in range(len(arr)-1-i):\n",
    "        if arr[j]<arr[j+1]:\n",
    "            tmp = arr[j]\n",
    "            arr[j] = arr[j+1]\n",
    "            arr[j+1] = tmp\n",
    "arr = [str(x) for x in arr]\n",
    "print(''.join(arr))"
   ]
  }
